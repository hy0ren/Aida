# Only for apps/mobile (Expo). See apps/ENV.md — do not put this in apps/web/.env.local.
# Copy to .env, set your computer's LAN IP, restart Expo.
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:3000

# Google OAuth public client IDs
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=837185143326-k05fjad97srq3m9iee3osdbr70cgkn51.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=837185143326-k05fjad97srq3m9iee3osdbr70cgkn51.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=837185143326-v8s27jl841cesgta6h5n1vlvnj6o55sg.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Expo Go uses this HTTPS redirect with the Google Web OAuth client.
# Add this exact URI to Google Console > Web client > Authorized redirect URIs.
# If you are signed into Expo, replace @anonymous/mobile with the value printed by AuthSession.getRedirectUrl().
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://auth.expo.io/@anonymous/mobile

# Native iOS/dev builds use the reversed iOS client ID as the callback scheme.
EXPO_PUBLIC_GOOGLE_IOS_REVERSED_CLIENT_ID=com.googleusercontent.apps.837185143326-v8s27jl841cesgta6h5n1vlvnj6o55sg:/oauthredirect
