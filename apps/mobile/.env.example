# Base URL of the Next.js API (no trailing slash). Required on a physical device:
# the default http://localhost:3000 is the phone itself, not your computer.
#
# 1) Find your machine's LAN IP (e.g. System Settings → Wi‑Fi on Mac, or `ipconfig`).
# 2) From repo root, run: cd apps/web && npm run dev
# 3) Set this and restart Expo (env is embedded at bundler start).
EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
